# ==============================================================================
# BILINGUAL WHATSAPP REAL ESTATE LEAD GENERATION SYSTEM — ENVIRONMENT CONFIG
# ==============================================================================
# Copy this file to a new file named '.env' and populate the actual secrets.
# Do NOT commit the '.env' file to Git.
# ==============================================================================

# 1. PostgreSQL Database Configuration
POSTGRES_USER=n8n_admin
POSTGRES_PASSWORD=change_this_to_a_secure_database_password
POSTGRES_DB=n8n_database
POSTGRES_PORT=5432

# 2. n8n Configuration
# A strong encryption key is mandatory to protect saved credentials in n8n's DB
N8N_ENCRYPTION_KEY=generate_a_long_random_string_of_characters_here
N8N_PORT=5678

# Webhook URL setup (The public URL where Meta sends webhook events).
# In development, our script will dynamically update this with the ngrok URL.
# In production, set this to your VPS public URL (e.g., https://api.youragency.ae)
WEBHOOK_URL=http://localhost:5678/

# 3. LLM/AI Integration (OpenAI API)
OPENAI_API_KEY=your_openai_api_key_here

# 4. WhatsApp Business Cloud API Configuration
# Get these from Meta Developers dashboard -> WhatsApp Setup
META_ACCESS_TOKEN=your_meta_whatsapp_cloud_api_access_token
META_VERIFY_TOKEN=your_secure_custom_webhook_verification_token

# 5. SALES LEAD STORAGE (Google Sheets CRM) - Where qualified leads are stored.
# The Google Spreadsheet ID
GOOGLE_SHEETS_ID=your_google_spreadsheet_id_here

# 6. DATABASE GUI CONSOLE (pgAdmin) - The UI interface to view tables live.
PGADMIN_PORT=8080
PGADMIN_EMAIL=admin@agency.ae
PGADMIN_PASSWORD=admin123
